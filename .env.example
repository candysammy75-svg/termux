# ════════════════════════════════════════
#  Dragon Shop Bot — متغيرات البيئة
# ════════════════════════════════════════

# توكن البوت من Discord Developer Portal
DISCORD_TOKEN=your_discord_token_here

# الـ Discord ID بتاعك (صاحب البوت)
OWNER_ID=your_discord_id_here

# الـ ID بتاع السيرفر
GUILD_ID=your_guild_id_here

# رابط قاعدة البيانات PostgreSQL
# مثال محلي:  postgresql://postgres:password@localhost:5432/dragonbot
# مثال Supabase: postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/dragonbot
